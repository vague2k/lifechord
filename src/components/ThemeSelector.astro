<div x-data={`{themeDropdownOpen: false}`} class="relative text-2xs">
    <button
        @click="themeDropdownOpen = !themeDropdownOpen"
        @click.away="themeDropdownOpen = false"
        class="nav-item text-foreground/60"
    >
        THEME▾
    </button>
    <ul
        x-show="themeDropdownOpen"
        class="absolute right-0 mt-[5px] w-36 border border-foreground/30 bg-background z-9999"
        role="listbox"
    >
        <li @click="setTheme('blue')" class="nav-item py-0.5">BLUE</li>
        <li @click="setTheme('maroon')" class="nav-item py-0.5">MAROON</li>
        <li @click="setTheme('green')" class="nav-item py-0.5">GREEN</li>
        <li @click="setTheme('mcd')" class="nav-item py-0.5">
            MCDONALDS (I LOVE THAT SHIT)
        </li>
    </ul>
</div>

<script is:inline>
    const THEME_KEY = "lifechord-theme";

    function setTheme(theme) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(THEME_KEY, theme);
    }

    function initThemeDropdown() {
        const saved = localStorage.getItem(THEME_KEY) || "blue";
        setTheme(saved);
    }

    document.addEventListener("DOMContentLoaded", initThemeDropdown);
    document.addEventListener("astro:page-load", initThemeDropdown);
</script>
