---
import "@/styles/global.css";
import BaseLayout from "@/layout/Base.astro";
---

<BaseLayout page="Lyrics">
    <a href="/" class="href-back">Back to home</a>
    <p class="mt-3 text-primary text-xs">
        Newly written songs, waiting to be put on a record...
    </p>
    <div class="flex flex-col text-2xs text-left">
        <a class="href-song-lyrics" href="/lyrics/new-songs/falling-short"
            >Falling Short (scrapped)</a
        >
        <a class="href-song-lyrics" href="/lyrics/new-songs/burn">Burn</a>
        <a class="href-song-lyrics" href="/lyrics/new-songs/shorelines"
            >Shorelines</a
        >
    </div>
    <p class="mt-3 text-primary text-xs">2026 - Screaming Through The Heart</p>
    <div class="flex flex-col text-2xs text-left">
        <a
            class="href-song-lyrics"
            href="/lyrics/screaming-through-the-heart/striving-for-connection"
            >1. Striving For Connection</a
        >
        <a
            class="href-song-lyrics"
            href="/lyrics/screaming-through-the-heart/the-indifference"
            >2. The Indifference</a
        >
    </div>
</BaseLayout>
