---
import BaseLayout from "@/layout/Base.astro";
import AudioPlayer from "@/components/AudioPlayer.astro";

const { title, audioSrc } = Astro.props;
---

<BaseLayout page="Lyrics">
    {
        audioSrc ? (
            <div class="flex justify-between items-center">
                <a href="/lyrics" class="href-back">
                    Back to lyrics
                </a>
                <div class="w-[75%]">
                    <AudioPlayer src={audioSrc} />
                </div>
            </div>
        ) : (
            <a href="/lyrics" class="href-back">
                Back to lyrics
            </a>
        )
    }
    <p class="mt-3 text-primary text-xs">{title}</p>
    <div class="flex flex-col gap-y-2 text-2xs text-left">
        <slot />
    </div>
</BaseLayout>
